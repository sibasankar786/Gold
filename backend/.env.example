# ─────────────────────────────────────────
# AstraTrade AI — Environment Config
# Copy to .env and fill in your values
# ─────────────────────────────────────────

# LLM (OpenAI)
OPENAI_API_KEY=sk-placeholder
# OpenAI Model (gpt-4o-mini is standard)
LLM_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small

# --- Gemini (Recommended Free Tier) ---
# Get one at https://aistudio.google.com/
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBED_MODEL=models/text-embedding-004

# MongoDB (local default or Atlas URI)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=astratrade

# ChromaDB local persistence path
CHROMA_PATH=./chroma_db

# News / Sentiment
NEWSAPI_KEY=your_newsapi_key_here

# Market Data
MARKET_SYMBOL=XAUUSD=X
MARKET_TIMEFRAME=1h
MARKET_BARS=200

# App
ENV=development
LOG_LEVEL=INFO
PORT=8000

# Risk defaults
DEFAULT_RISK_PCT=0.5
MAX_DAILY_TRADES=3
MAX_DAILY_LOSS_PCT=2.0

# Forward test gate
FORWARD_TEST_MIN_TRADES=100
FORWARD_TEST_MIN_DAYS=30
